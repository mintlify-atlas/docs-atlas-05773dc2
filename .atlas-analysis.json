  "keyFeatures": [
    "Role-based access control with 4 user levels (Owner, Supervisor, Operator, Admin)",
    "Complete work order lifecycle management from quotation to delivery",
    "Real-time resource and material tracking with inventory management",
    "Operation logging and full audit trail for compliance",
    "Dashboard with KPIs, productivity reports and charts",
    "Multi-tenant architecture with company isolation"
  ],
